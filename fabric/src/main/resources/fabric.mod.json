{
  "schemaVersion": 1,
  "id": "mcmodupdater",
  "version": "0.4.0",
  "name": "MC Mod Auto-Updater",
  "description": "Minecraft 客户端模组自动更新器。启动时拉取 Modrinth 整合包清单，弹窗显示差异并同步 mods 目录。",
  "authors": [
    "cyhqw"
  ],
  "contact": {
    "homepage": "https://github.com/cyhqw/mc-mod-autoupdater",
    "sources": "https://github.com/cyhqw/mc-mod-autoupdater",
    "issues": "https://github.com/cyhqw/mc-mod-autoupdater/issues"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.cyhqw.mcmodupdater.fabric.McModUpdaterFabric"
    ]
  },
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.20.1",
    "java": ">=17"
  },
  "recommends": {
    "fabric-api": "*"
  }
}
