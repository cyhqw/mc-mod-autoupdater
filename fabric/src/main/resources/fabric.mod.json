{
  "schemaVersion": 1,
  "id": "mcmodupdater",
  "version": "0.2.0",
  "name": "MC Mod Auto-Updater",
  "description": "Client-only mod: fetches a Modrinth modpack index (modrinth.index.json) from a URL and syncs the local mods folder at game launch.",
  "authors": [
    "cyhqw"
  ],
  "contact": {
    "homepage": "https://github.com/cyhqw/mc-mod-autoupdater",
    "sources": "https://github.com/cyhqw/mc-mod-autoupdater",
    "issues": "https://github.com/cyhqw/mc-mod-autoupdater/issues"
  },
  "license": "MIT",
  "icon": "assets/mcmodupdater/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.cyhqw.mcmodupdater.fabric.McModUpdaterFabricClient"
    ]
  },
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "~1.20.1",
    "java": ">=17"
  }
}
