# =============================================================
# MC Mod Auto-Updater 客户端配置示例
# 复制到 <游戏目录>/config/mcmodupdater/mcmodupdater.properties 后修改
#
# 本模组纯客户端运行：从下面配置的 URL 拉取 Modrinth 整合包格式的
# modrinth.index.json，同步本地 mods 目录。
# =============================================================

# 指向 modrinth.index.json 的 URL（HTTP/HTTPS）。
# 留空则使用默认 URL：本仓库根目录下的 modrinth.index.json
#   https://raw.githubusercontent.com/cyhqw/mc-mod-autoupdater/main/modrinth.index.json
# 自定义示例：
#   manifestUrl=https://your-host.example.com/mc/modrinth.index.json
#   manifestUrl=https://raw.githubusercontent.com/you/your-repo/main/modrinth.index.json
manifestUrl=

# 启动时自动同步。
autoSyncOnLaunch=true

# 周期性同步间隔（分钟）。0 = 禁用；>0 = 每 N 分钟检查一次 manifest 是否更新。
# 默认禁用。建议 30-60 分钟。
periodicSyncMinutes=0

# 自定义 mods 目录路径（绝对或相对游戏目录）。为空则用默认的 mods/。
# 示例：
#   modsDir=mods              （默认行为）
#   modsDir=/opt/mc-client-mods
modsDir=

# 覆盖 tracked mod 前备份为 .bak。
# 注意：模组只管理自己下载过的 mod（tracked mod），
# 玩家手动添加的 mod 永远不会被删除或覆盖。
backupOldMods=true

# 并发下载线程数。
maxConcurrentDownloads=4

# 下载后校验 SHA1，不匹配则拒绝。
verifyHash=true

# HTTP 请求超时（毫秒）。0 表示使用默认值（15000）。
httpTimeoutMs=15000

# 单文件下载失败时的最大重试次数。
maxRetries=2

# 有变化时提示玩家重启。
promptRestart=true

# 黑名单：跳过指定 mod 文件名（逗号分隔，不带路径）。
# 示例：skipMods=optifine.jar,sodium.jar
skipMods=

# 白名单：仅同步这些 mod 文件名（逗号分隔）。为空则不过滤。
# 示例：onlyMods=fabric-api.jar,sodium.jar,jei.jar
onlyMods=
