# CurseForge slug → modId 映射文件
#
# 用途：当 Modrinth 上找不到某个 mod 时（如 SHA1 不匹配、版本不同、CF 独占），
# scan_mods.py 会用此文件查 CurseForge，按文件名匹配 CF 上的 file。
#
# 格式（每行一条）：
#   slug=modId
#   # 注释行（以 # 开头）
#   slug=modId  # 行内注释也支持
#
# slug 不区分大小写，但建议用 CurseForge URL 中的 slug 原样。
#
# 如何获取 modId：
#   1. 打开 CurseForge 网页，例如 https://www.curseforge.com/minecraft/mc-mods/waystones
#   2. 在网页源码或 F12 开发者工具中找 projectId
#   3. 或者用 CurseForge API: GET /mods/{modId} 测试数字 ID
#
# 常见 mod 的 modId 参考（用户可按需添加）：

# Waystones
waystones=245755

# Placebo (FTB 系列前置)
placebo=273510

# Simple Voice Chat
voicechat=416089

# Clumps (经验球合并)
clumps=256717

# FTB Ultimine (连锁破坏)
ftb-ultimine=448839

# FTB Library (FTB 系列前置)
ftb-library=403521

# AE2 ExtendedAE (CurseForge 版本)
extended-ae=892005

# Litematica Printer
litematica-printer=546654

# Mekanism (有时 CF 与 Modrinth 不同步)
mekanism=261848

# OpenYSM (YSM 客户端)
openysm=876877

# WebDisplays
webdisplays=287666

# SecureExplosion
secureexplosion=908823
